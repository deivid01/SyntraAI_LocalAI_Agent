{
  "name": "jarvis-local-ai",
  "version": "1.0.0",
  "description": "Assistente pessoal estilo Jarvis - 100% local",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "dev:watch": "concurrently \"tsc -w\" \"electron .\"",
    "build": "tsc && electron-builder",
    "start:ai": "ollama run mistral",
    "install:deps": "powershell -ExecutionPolicy Bypass -File install.ps1",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "jarvis",
    "ai",
    "electron",
    "local",
    "assistant"
  ],
  "author": "Wellington Luiz",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.5",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "sql.js": "^1.10.3",
    "wav": "^1.0.2"
  },
  "build": {
    "extends": null,
    "appId": "com.jarvis.localai",
    "productName": "JarvisAI",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JarvisAI",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "runAfterFinish": true
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "src/database/schema.sql",
      "assets/**/*",
      "node_modules/**/*",
      "package.json",
      "install.ps1",
      ".env"
    ]
  }
}
